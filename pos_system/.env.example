API_BASE_URL=http://localhost:8000
API_TOKEN=dev-static-token
# Optional: Django-style CSRF (some operations may require it; safe to leave empty for local GET).
API_CSRF_TOKEN=
# If 1: API field valorUnitario is already in centavos. If 0 (default): valorUnitario is in reais (×100).
API_PRODUCT_VALOR_UNITARIO_IN_CENTS=0
# CNPJ do estabelecimento (obigatório para calculate-tolerance na saída e para POST /api/payments/ com catraca)
API_CNPJ=
API_EQUIPAMENTO_ID=
API_PAYMENT_QUANTIDADE=1
PAYMENT_PROVIDER=mock
PAYMENT_API_KEY=your-payment-api-key
ASAAS_API_BASE_URL=https://sandbox.asaas.com/api/v3
ASAAS_CUSTOMER_ID=
ASAAS_BILLING_TYPE=PIX
PAYMENT_STATUS_POLL_ATTEMPTS=6
PAYMENT_STATUS_POLL_INTERVAL_SECONDS=2
DEVICE_ID=POS-001
TIMEOUT_SECONDS=2
RETRY_LIMIT=5
